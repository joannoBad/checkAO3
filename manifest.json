{
  "manifest_version": 2,
  "name": "checkAO3",
  "version": "0.2.0",
  "description": "Track AO3 author work stats from Firefox without opening individual works.",
  "permissions": [
    "storage",
    "tabs",
    "https://archiveofourown.org/*"
  ],
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "browser_action": {
    "default_title": "checkAO3",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.svg",
      "96": "icons/icon-96.svg"
    }
  },
  "background": {
    "scripts": [
      "lib/dates.js",
      "lib/storage.js",
      "background/background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://archiveofourown.org/*"
      ],
      "js": [
        "content/ao3-parser.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "checkao3@example.com"
    }
  }
}
